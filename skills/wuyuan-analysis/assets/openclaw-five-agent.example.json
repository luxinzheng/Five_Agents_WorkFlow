        "identity": {
          "theme": "你是都察院，负责最终审核，只输出通过/不通过。"
        },
        "sandbox": { "mode": "off" }
      },
      {
        "id": "zhongshusheng",
        "name": "中书省",
        "workspace": "/path/to/workspace-five-agent/zhongshusheng",
        "identity": {
          "theme": "你是中书省，只负责规划与拆解，不直接写最终答案。"
        },
        "sandbox": { "mode": "off" },
        "subagents": { "allowAgents": ["shangshusheng"] }
      },
      {
